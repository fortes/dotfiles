#!/usr/bin/env bash
# Set node to LTS and install global packages
#
# Usage: install_node_packages

set -euo pipefail
IFS=$'\n\t'
BUN_PACKAGES=(
  # @google/jules
  # @mariozechner/pi-coding-agent
  @openai/codex
  @playwright/mcp
  @tobilu/qmd
  @typescript/native-preview
  agent-browser
  bash-language-server
  cssmodules-language-server
  dockerfile-language-server-nodejs
  eslint
  fkill-cli
  neovim
  npm-check-updates
  # opencode-ai
  oxfmt
  oxlint
  prettier
  tsx
  typescript
  typescript-language-server
  vim-language-server
  vscode-langservers-extracted
)

# Bun's hoisting fails to resolve nested peer-deps for these packages:
# - copilot-language-server bundles its own language server binary
# - yaml-language-server's ajv-draft-04 dep does `require('ajv/dist/core')`
NPM_PACKAGES=(
  @github/copilot-language-server
  yaml-language-server
)

# shellcheck source=script/lib.sh
. "$(dirname "${BASH_SOURCE[0]}")/lib.sh"

print_usage() {
  cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Set node to LTS and install global packages

Options:
  -p, --packages-only   Only install packages, skip Node.js installation
                        (useful for updating packages without changing Node version)
  -h, --help           Show this help message
EOF
}

install_node_packages() {
  # Parse arguments
  local packages_only=0

  while [[ "$#" -gt 0 ]]; do
    case "${1}" in
      -p | --packages-only)
        packages_only=1
        shift
        ;;
      -h | --help)
        print_usage
        exit 0
        ;;
      *)
        >&2 echo "Unknown option: ${1}"
        print_usage
        exit 1
        ;;
    esac
  done

  if ! command_exists fnm; then
    >&2 echo "⨯ fnm not installed"
    exit 1
  fi

  if [[ "${packages_only}" -eq 0 ]]; then
    echo "Installing node LTS …"

    # Use --arch arm64 when running on aarch64, otherwise fnm doesn't
    # auto-detect (happens on Docker on MacOS)
    if [[ "$(uname -m)" == "aarch64" ]]; then
      fnm install --lts --arch "arm64"
    else
      fnm install --lts
    fi

    echo "Setting node version to LTS …"
    fnm default "lts-latest"
  else
    echo "Only installing packages (--packages-only flag provided)"
  fi

  # Make sure to pick up necessary env vars
  eval "$(fnm env)"

  if ! command_exists node; then
    >&2 echo "⨯ Node.js not found on PATH after fnm env"
    exit 1
  fi

  if ! command_exists corepack; then
    >&2 echo "⨯ corepack not found (should be included with Node.js)"
    exit 1
  fi

  echo "Using Node $(node --version)"

  if [[ -f "$HOME/.profile" ]]; then
    # shellcheck source=/dev/null
    . "$HOME/.profile"
  else
    # .profile / .npmrc may not be stowed yet during the docker build
    export BUN_INSTALL="$HOME/.local"
  fi

  # npm prefix lives in stowed .npmrc, but we may run before stow. Set it
  # here so npm globals always land in ~/.local/bin (alongside bun globals).
  export NPM_CONFIG_PREFIX="$HOME/.local"

  # Make pnpm/yarn available on demand for project-local work
  corepack enable

  if ! command_exists bun; then
    >&2 echo "⨯ bun not installed (expected on PATH from install_github_packages or brew)"
    exit 1
  fi

  echo "Installing global bun packages …"
  bun install --global --silent "${BUN_PACKAGES[@]}"
  echo "Bun packages installed!"

  if [[ ${#NPM_PACKAGES[@]} -gt 0 ]]; then
    echo "Installing global npm packages …"
    npm install --global --silent --no-fund --no-audit "${NPM_PACKAGES[@]}"
    echo "Npm packages installed!"
  fi
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  install_node_packages "${@}"
fi
